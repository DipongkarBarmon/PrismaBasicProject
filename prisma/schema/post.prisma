model Post {
  id         String     @id @default(uuid())
  title      String
  content    String
  thumbnail  String?
  isFeatured Boolean @default(false)
  status     PostStatus @default(PUBLISHED)
  tags       String[]
  authoId    String
  author   User   @relation(fields: [authoId], references: [id], onDelete: Cascade)
  views      Int     @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  comments   Comment[]

  @@index([authoId])
  @@map("posts")
}
